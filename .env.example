# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://graphuser:CHANGE_ME@postgres:5432/graphdb
POSTGRES_USER=graphuser
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=graphdb

# ─── Neo4j ────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_PASSWORD=CHANGE_ME
NEO4J_AUTH=neo4j/CHANGE_ME

# ─── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_URL=redis://redis:6379/0

# ─── FastAPI ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:5173,https://your-production-domain.com
# Shared secret — backend validates X-API-Key header against this value
API_KEY=CHANGE_ME

# ─── MLflow ───────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000

# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
# Copy these to frontend/.env
VITE_API_BASE_URL=http://localhost:8000
VITE_API_KEY=CHANGE_ME
